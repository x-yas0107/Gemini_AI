void setup() {
    RCC->APB2PCENR |= RCC_AFIOEN | RCC_IOPCEN | RCC_IOPDEN;
    GPIOC->CFGLR &= ~((0xF << 24) | (0xF << 28));
    GPIOC->CFGLR |=  ((0x5 << 24) | (0x5 << 28)); // PC6, PC7 Out
    
    uart_init();
    uart_print("\r\n--- Font Installer Phase 2 (Katakana) ---\r\n");
    uart_print("Starting EEPROM Write to 0x02DB...\r\n");

    uint16_t eeprom_addr = 0x02DB;
    
    for (int i = 0; i < 63; i++) {
        for (int j = 0; j < 5; j++) {
            eeprom_write_byte(eeprom_addr, font_data_kana[i][j]);
            eeprom_addr++;
        }
        if (i % 10 == 0) uart_print("."); // Progress dot
    }

    uart_print("\r\nWrite Complete! Katakana Installed.\r\n");
    uart_print("You can now flash the main OS (V0.27).\r\n");
}

void loop() {
    delay(1000);
}